.cinema-detail-container {
  min-height: 100vh;
  background: #F5F6F7;
  padding-bottom: 40rpx;
}

/* ========== 顶部信息区域 ========== */
.header-section {
  background: #FFFFFF;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.movie-info {
  display: flex;
  align-items: center;
}
.movie-poster {
  width: 120rpx;
  height: 170rpx;
  border-radius: 12rpx;
  background: #EEE;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}
.movie-detail {
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}
.movie-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}
.movie-tags {
  font-size: 26rpx;
  color: #999;
  background: #F5F5F5;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
}

.divider {
  height: 1rpx;
  background: linear-gradient(to right, transparent, #EEEEEE, transparent);
  margin: 30rpx 0;
}

.cinema-info {
  display: flex;
  flex-direction: column;
}
.cinema-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.cinema-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.location-icon {
  font-size: 40rpx;
  color: #FF5722;
}
.cinema-address {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}
.cinema-tags {
  display: flex;
  flex-wrap: wrap;
}
.tag-item {
  font-size: 22rpx;
  color: #666;
  background: #F5F5F5;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

/* ========== 日期选择器 ========== */
.date-bar {
  background: #FFFFFF;
  padding: 24rpx 0;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.date-scroll {
  white-space: nowrap;
  padding: 0 30rpx;
}
.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 110rpx;
  padding: 20rpx 0;
  margin-right: 24rpx;
  border-radius: 16rpx;
  background: #F8F9FA;
  transition: all 0.3s;
}
.date-item.active {
  background: linear-gradient(135deg, #FF6B35 0%, #FF5722 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(255,87,34,0.4);
  transform: translateY(-4rpx);
}
.date-week {
  font-size: 26rpx;
  margin-bottom: 8rpx;
}
.date-day {
  font-size: 32rpx;
  font-weight: bold;
}

/* ========== 场次列表 ========== */
.schedule-section {
  margin: 0 30rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 16rpx;
}
.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.title-count {
  font-size: 26rpx;
  color: #999;
  background: #F5F5F5;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.schedule-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

/* 🎨 排片卡片 */
.schedule-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 2rpx solid #F0F0F0;
  transition: all 0.3s;
}
.schedule-card:last-child {
  margin-bottom: 0;
}
.schedule-card:active {
  transform: scale(0.98);
  background: #FAFAFA;
}
.schedule-card.sold-out {
  opacity: 0.6;
  background: #F9F9F9;
  border-color: #E0E0E0;
}

/* 左侧时间区域 */
.schedule-time {
  display: flex;
  align-items: center;
  min-width: 200rpx;
}
.start-time {
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
}
.time-divider {
  width: 1rpx;
  height: 28rpx;
  background: #DDD;
  margin: 0 14rpx;
}
.end-time {
  font-size: 26rpx;
  color: #999;
}

/* 中间厅名区域 */
.schedule-hall {
  flex: 1;
  margin: 0 20rpx;
}
.hall-name {
  font-size: 26rpx;
  color: #666;
  background: #F5F5F5;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
}

/* ✅ 右侧：价格 + 状态 - 垂直居中对齐 */
.schedule-action {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
  min-width: 120rpx;
  gap: 8rpx;
}

/* 💰 价格 */
.price {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF5722;
  line-height: 1;
}

/* 🏷️ 状态标签 */
.status-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: #E3F2FD;
  color: #1976D2;
  line-height: 1;
}
.status-badge.info {
  background: #E3F2FD;
  color: #1976D2;
}
.status-badge.success {
  background: #E8F5E9;
  color: #388E3C;
}
.status-badge.warning {
  background: #FFF3E0;
  color: #F57C00;
}
.status-badge.error {
  background: #FFEBEE;
  color: #D32F2F;
}

/* 售罄状态 */
.schedule-card.sold-out .price {
  color: #999;
  text-decoration: line-through;
}
.schedule-card.sold-out .status-badge {
  background: #FFEBEE;
  color: #D32F2F;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-top: 20rpx;
}
.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}
.empty-text {
  color: #666;
  font-size: 30rpx;
  margin-bottom: 10rpx;
}
.empty-hint {
  color: #999;
  font-size: 26rpx;
}