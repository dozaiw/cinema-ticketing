<view class="login-container">
  <view class="logo-area">
    <text class="logo-text">天天影院</text>
    <text class="slogan">欢迎登录</text>
  </view>

  <view class="form-area">
    <!-- 手机号/用户名 -->
    <view class="form-item">
      <text class="label">手机号</text>
      <input 
        class="input" 
        type="number" 
        maxlength="11" 
        placeholder="请输入手机号" 
        value="{{username}}" 
        bindinput="onUsernameInput" 
      />
    </view>

    <!-- 密码 -->
    <view class="form-item">
      <text class="label">密码</text>
      <input 
        class="input" 
        type="password" 
        placeholder="请输入密码" 
        value="{{password}}" 
        bindinput="onPasswordInput" 
      />
    </view>

    <!-- 登录按钮 -->
    <button class="login-btn" bindtap="onLogin">登录</button>

    <!-- 跳转注册 -->
    <view class="register-link">
      <text>没有账号？</text>
      <text class="link-text" bindtap="goToRegister">立即注册</text>
    </view>
  </view>
</view>