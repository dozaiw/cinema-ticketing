.verify-page {
  min-height: 100vh;
  padding: 32rpx;
  background: linear-gradient(180deg, #fff7ed 0%, #f8fafc 240rpx, #f8fafc 100%);
  box-sizing: border-box;
}

.hero-card,
.verify-card,
.result-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.06);
}

.hero-card {
  background: linear-gradient(135deg, #f97316, #ea580c);
  color: #ffffff;
  margin-bottom: 24rpx;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
}

.hero-subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.9);
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 20rpx;
}

.verify-input {
  width: 100%;
  min-height: 92rpx;
  padding: 0 28rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #0f172a;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.primary-btn,
.secondary-btn,
.reset-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.primary-btn {
  color: #ffffff;
  background: linear-gradient(90deg, #f97316, #ea580c);
}

.secondary-btn {
  color: #c2410c;
  background: #fff7ed;
  border: 2rpx solid #fdba74;
}

.result-card {
  margin-top: 24rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.result-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #166534;
}

.result-time {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
}

.success-tag {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #dcfce7;
  color: #166534;
  font-size: 24rpx;
  font-weight: 600;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.result-item {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.result-label {
  width: 140rpx;
  color: #64748b;
  font-size: 26rpx;
}

.result-value {
  flex: 1;
  text-align: right;
  color: #0f172a;
  font-size: 28rpx;
  word-break: break-all;
}

.reset-btn {
  width: 100%;
  margin-top: 32rpx;
  color: #0f172a;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
}
