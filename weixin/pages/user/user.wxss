/* 容器 */
.user-container {
  min-height: 100vh;
  background: #F5F6F7;
  padding-bottom: 40rpx;
}

/* 头部背景渐变 */
.header-bg {
  height: 300rpx;
  background: linear-gradient(135deg, #FF5722 0%, #FF7043 100%);
  position: relative;
}

/* 用户信息卡片 */
.user-card {
  background: #FFFFFF;
  margin: -100rpx 30rpx 30rpx;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 87, 34, 0.15);
  position: relative;
}

/* 用户信息 */
.user-info {
  display: flex;
  align-items: center;
}

/* 头像 */
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #FFF5F5;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.avatar-default {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFE4E1 0%, #FFD6CC 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  border: 4rpx solid #FFF5F5;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 用户详情 */
.user-details {
  flex: 1;
  margin-left: 30rpx;
  display: flex;
  flex-direction: column;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.phone {
  font-size: 26rpx;
  color: #999999;
}

.role-badge {
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.role-admin {
  color: #B54708;
  background: #FFF1D6;
}

.role-user {
  color: #475467;
  background: #EAECF0;
}

/* 登录按钮 */
.login-btn {
  background: linear-gradient(90deg, #FF5722, #FF7043);
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
  border-radius: 30rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(255, 87, 34, 0.3);
}

/* 功能菜单区域 */
.menu-section {
  margin: 0 30rpx 30rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

/* 菜单列表 */
.menu-list {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
  transition: background 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #FAFAFA;
}

.menu-left {
  display: flex;
  align-items: center;
}

.icon {
  font-size: 40rpx;
  margin-right: 24rpx;
  width: 50rpx;
  text-align: center;
}

.text {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.menu-texts {
  display: flex;
  flex-direction: column;
}

.subtext {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999999;
}

.arrow {
  font-size: 40rpx;
  color: #CCCCCC;
  font-weight: 300;
}

/* 退出登录按钮 */
.logout-btn {
  margin: 0 30rpx;
  background: #FFFFFF;
  color: #FF5722;
  font-size: 30rpx;
  font-weight: 500;
  padding: 30rpx 0;
  border-radius: 24rpx;
  border: 2rpx solid #FFE4E1;
  box-shadow: 0 4rpx 16rpx rgba(255, 87, 34, 0.1);
}

.logout-btn:active {
  background: #FFF5F5;
}
