<view class="user-container">
  <!-- 头部背景 -->
  <view class="header-bg"></view>

  <!-- 用户信息卡片 -->
  <view class="user-card">
    <!-- 已登录状态 -->
    <view class="user-info" wx:if="{{isLogin}}">
      <image src="{{userInfo.avatar}}" class="avatar" wx:if="{{userInfo.avatar}}" />
      <view class="avatar-default" wx:else>👤</view>
      <view class="user-details">
        <view class="name-row">
          <text class="nickname">{{userInfo.nickname}}</text>
          <text class="role-badge {{isAdmin ? 'role-admin' : 'role-user'}}">
            {{isAdmin ? '管理员' : '普通用户'}}
          </text>
        </view>
        <text class="phone">{{userInfo.phone}}</text>
      </view>
    </view>

    <!-- 未登录状态 -->
    <view class="user-info" wx:else bindtap="goToLogin">
      <view class="avatar-default">👤</view>
      <view class="user-details">
        <text class="nickname">未登录</text>
        <text class="phone">登录后享受更多服务</text>
      </view>
      <view class="login-btn">立即登录</view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <text class="section-title">我的服务</text>
    <view class="menu-list">
      <view class="menu-item" bindtap="goOrders">
        <view class="menu-left">
          <text class="icon">🎫</text>
          <text class="text">我的订单</text>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goFavorites">
        <view class="menu-left">
          <text class="icon">❤️</text>
          <text class="text">我的收藏</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="menu-section" wx:if="{{isLogin && isAdmin}}">
    <text class="section-title">管理功能</text>
    <view class="menu-list">
      <view class="menu-item" bindtap="goVerifyCenter">
        <view class="menu-left">
          <text class="icon">✅</text>
          <view class="menu-texts">
            <text class="text">验票中心</text>
            <text class="subtext">扫码或输入验票码核销电影票</text>
          </view>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 退出登录按钮 -->
  <button class="logout-btn" wx:if="{{isLogin}}" bindtap="logout">退出登录</button>
</view>
