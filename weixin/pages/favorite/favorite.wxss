/* 容器 */
.favorite-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  background: #FFFFFF;
  padding: 30rpx 30rpx 20rpx;
  display: flex;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.count {
  font-size: 28rpx;
  color: #999;
  margin-left: 10rpx;
}

/* 电影列表 */
.movie-list {
  padding: 20rpx 30rpx;
}

/* 电影卡片 */
.movie-item {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.poster {
  width: 180rpx;
  height: 250rpx;
  border-radius: 8rpx;
  background: #EEE;
  flex-shrink: 0;
}

.info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.info .title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  margin-right: 10rpx;
}

.status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  background: #F5F5F5;
  white-space: nowrap;
}

.desc-box {
  margin: 10rpx 0;
}

.desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.tags {
  display: flex;
  font-size: 22rpx;
  color: #999;
  margin: 5rpx 0;
}

.tag {
  margin-right: 15rpx;
}

.bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.price {
  color: #FF5722;
  font-size: 30rpx;
  font-weight: bold;
}

.buy-btn {
  background: #FF5722;
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  border: none;
  line-height: 1.5;
  margin: 0;
}

.buy-btn:active {
  background: #FF7043;
}

.status-tip {
  font-size: 24rpx;
  color: #999;
}

.unfavorite-btn {
  background: #FFFFFF;
  color: #FF5722;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid #FF5722;
  margin: 0;
}

.unfavorite-btn:active {
  background: #FFF5F5;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
