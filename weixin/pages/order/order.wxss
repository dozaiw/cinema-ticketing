/* pages/order/order.wxss */
page {
  background-color: #f5f5f5;
  min-height: 100%;
}

.container {
  padding: 20rpx;
}

/* ========== 订单列表 ========== */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  position: relative;
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 20rpx;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  font-size: 26rpx;
  font-weight: 500;
}

/* 电影信息 */
.movie-section {
  margin-bottom: 20rpx;
}

.movie-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-text {
  font-size: 26rpx;
  color: #666;
}

.divider {
  color: #ccc;
}

/* 座位信息 */
.seat-section {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.seat-section .label {
  font-size: 26rpx;
  color: #666;
  margin-right: 8rpx;
}

.seat-info {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

/* 金额信息 */
.amount-section {
  display: flex;
  justify-content: flex-end;
  align-items: baseline;
}

.amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4d4f;
}

/* 操作按钮 */
.action-section {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.btn-cancel,
.btn-pay,
.btn-refund {
  width: 180rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 26rpx;
  border-radius: 30rpx;
  border: none;
  padding: 0;
}

.btn-cancel {
  background-color: #fff;
  color: #999;
  border: 1rpx solid #ddd;
}

.btn-pay {
  background-color: #ff4d4f;
  color: #fff;
}

.btn-refund {
  background-color: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
}

.btn-cancel::after,
.btn-pay::after,
.btn-refund::after {
  border: none;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.5;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.btn-home {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #ff4d4f;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

/* ========== 加载状态 ========== */
.loading-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
