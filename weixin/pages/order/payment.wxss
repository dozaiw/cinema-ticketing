/* pages/order/payment.wxss */
page {
  background-color: #f5f5f5;
  min-height: 100%;
  display: flex;
  flex-direction: column;
}

.payment-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  background-color: #fff;
}

/* ========== 支付头部 ========== */
.payment-header {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.amount-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.amount-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.amount-value {
  font-size: 80rpx;
  font-weight: bold;
  color: #333;
}

.balance-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.balance-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.balance-value {
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: 500;
}

/* ========== 支付信息 ========== */
.payment-info {
  padding: 0 40rpx 40rpx;
  text-align: center;
}

.info-text {
  font-size: 26rpx;
  color: #999;
}

/* ========== 密码输入框 ========== */
.password-section {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.password-input {
  background-color: #f8f8f8;
  border-radius: 16rpx;
  padding: 30rpx 40rpx;
  width: 100%;
  max-width: 600rpx;
  box-sizing: border-box;
}

.dots-container {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  background-color: #fff;
  flex: 1;
  max-width: 36rpx;
  transition: all 0.2s;
}

.dot.filled {
  background-color: #333;
  border-color: #333;
}

.forget-password {
  margin-top: 30rpx;
}

.forget-text {
  font-size: 26rpx;
  color: #576b95;
}

/* ========== 数字键盘 ========== */
.keyboard {
  flex: 1;
  background-color: #f0f0f0;
  padding: 20rpx 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.keyboard-row {
  display: flex;
  gap: 20rpx;
  padding: 10rpx 30rpx;
  margin-bottom: 10rpx;
}

.keyboard-item {
  flex: 1;
  height: 100rpx;
  background-color: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: background-color 0.1s;
}

.keyboard-item:active {
  background-color: #f0f0f0;
}

.keyboard-item.empty {
  background-color: transparent;
  box-shadow: none;
}

.key-text {
  font-size: 40rpx;
  font-weight: 500;
  color: #333;
}

.delete-icon {
  width: 48rpx;
  height: 48rpx;
}

.cancel-item {
  background-color: #ddd;
}

.cancel-item:active {
  background-color: #ccc;
}

.cancel-text {
  font-size: 32rpx;
  color: #333;
}
