<!-- pages/order/order-confirm.wxml -->
<view class="container">
  <!-- 订单信息卡片 -->
  <view class="order-card">
    <view class="card-header">
      <text class="title">订单详情</text>
      <text class="order-no">订单号：{{orderNo}}</text>
    </view>

    <!-- 电影信息 -->
    <view class="movie-info">
      <text class="movie-name">{{movieName}}</text>
      <view class="info-row">
        <text class="label">影院：</text>
        <text class="value">{{cinemaName}}</text>
      </view>
      <view class="info-row">
        <text class="label">影厅：</text>
        <text class="value">{{hallName}}</text>
      </view>
      <view class="info-row">
        <text class="label">时间：</text>
        <text class="value">{{showTime}}</text>
      </view>
    </view>

    <!-- 座位信息 -->
    <view class="seat-section">
      <text class="section-title">座位</text>
      <view class="seat-tags">
        <view class="seat-tag" wx:for="{{seatNames}}" wx:key="*this">
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 价格信息 -->
    <view class="price-section">
      <view class="price-row">
        <text class="label">票价</text>
        <text class="value">¥{{price}} × {{seatIds.length}}座</text>
      </view>
      <view class="total-row">
        <text class="label">合计</text>
        <text class="total-price">¥{{amount}}</text>
      </view>
    </view>
  </view>

  <!-- 未支付状态 -->
  <view wx:if="{{!paid}}" class="action-card">
    <!-- 倒计时 -->
    <view class="countdown-section">
      <text class="countdown-label">支付剩余时间</text>
      <text class="countdown">{{countdown}}</text>
    </view>

    <!-- 按钮组 -->
    <view class="btn-group">
      <button class="btn cancel-btn" bindtap="handleCancel">取消订单</button>
      <button class="btn pay-btn" bindtap="goToPayment">立即支付</button>
    </view>
  </view>

  <!-- 已支付状态 -->
  <view wx:if="{{paid}}" class="success-card">
    <!-- 二维码 -->
    <view class="qrcode-section" wx:if="{{qrCodeUrl}}">
      <image class="qrcode" src="{{qrCodeUrl}}" mode="aspectFit"></image>
      <text class="qrcode-tip">凭此二维码入场</text>
    </view>

    <!-- 验证码 -->
    <view class="verify-section">
      <text class="verify-label">验证码</text>
      <view class="verify-code" bindtap="copyVerifyCode">
        <text>{{verifyCode}}</text>
        <text class="copy-hint">点击复制</text>
      </view>
    </view>

    <!-- 票务信息 -->
    <view class="ticket-info">
      <view class="ticket-item">
        <text class="t-label">电影</text>
        <text class="t-value">{{ticketInfo.movieName}}</text>
      </view>
      <view class="ticket-item">
        <text class="t-label">影院</text>
        <text class="t-value">{{cinemaName}}</text>
      </view>
      <view class="ticket-item">
        <text class="t-label">影厅</text>
        <text class="t-value">{{ticketInfo.hallName}}</text>
      </view>
      <view class="ticket-item">
        <text class="t-label">时间</text>
        <text class="t-value">{{ticketInfo.showTime}}</text>
      </view>
      <view class="ticket-item">
        <text class="t-label">座位</text>
        <text class="t-value">{{ticketInfo.seatInfo}}</text>
      </view>
      <view class="ticket-item">
        <text class="t-label">支付时间</text>
        <text class="t-value">{{ticketInfo.payTime}}</text>
      </view>
    </view>

    <button class="btn back-btn" bindtap="navigateToOrderList">查看我的订单</button>
    <button class="btn refund-btn" bindtap="handleRefund">申请退款</button>
  </view>
</view>
