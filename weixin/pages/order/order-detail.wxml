<!-- pages/order/order-detail.wxml -->
<view class="container">
  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 订单详情 -->
  <view class="detail-container" wx:if="{{orderDetail && !loading}}">
    <!-- 订单头部 -->
    <view class="header">
      <text class="title">订单详情</text>
      <view class="header-right">
        <text class="status" style="color: {{statusColor}};">{{statusText}}</text>
        <text class="countdown" wx:if="{{statusText === '待支付' && countdown}}">还剩 {{countdown}} 支付</text>
      </view>
    </view>

    <!-- 订单号 -->
    <view class="info-row">
      <text class="label">订单编号：</text>
      <text class="value">{{orderDetail.orderNo}}</text>
    </view>

    <!-- 电影信息 -->
    <view class="card movie-card">
      <view class="card-header">电影信息</view>
      <view class="card-body">
        <view class="movie-name">{{orderDetail.movieName}}</view>
        <view class="info-row">
          <text class="info-text">{{cinemaName}}</text>
        </view>
        <view class="info-row">
          <text class="info-text">{{orderDetail.hallName}}</text>
          <text class="divider">|</text>
          <text class="info-text">{{showTime}}</text>
        </view>
        <view class="info-row seat-info">
          <text class="info-label">座位：</text>
          <text class="info-text">{{seatNames}}</text>
        </view>
      </view>
    </view>

    <!-- 金额信息 -->
    <view class="card amount-card">
      <view class="card-header">金额信息</view>
      <view class="card-body">
        <view class="amount-row">
          <text class="amount-label">订单金额</text>
          <text class="amount-value">¥{{displayAmount}}</text>
        </view>
        <view class="pay-time" wx:if="{{statusText === '已支付' || statusText === '已使用'}}">
          <text class="pay-label">支付时间：</text>
          <text class="pay-value">{{payTime}}</text>
        </view>
      </view>
    </view>

    <!-- 验证信息 -->
    <view class="card verify-card" wx:if="{{statusText === '已支付' || statusText === '已使用'}}">
      <view class="card-header">取票信息</view>
      <view class="card-body">
        <view class="qr-code-section" wx:if="{{showQrCode}}" bindtap="previewQrCode">
          <image class="qr-code" src="{{qrCodeUrl}}" mode="aspectFit"></image>
          <text class="qr-tip">点击放大</text>
        </view>
        <view class="verify-code-section" bindtap="copyVerifyCode">
          <text class="verify-label">验证码：</text>
          <text class="verify-code">{{verifyCode}}</text>
          <text class="copy-tip">点击复制</text>
        </view>
      </view>
    </view>

    <!-- 订单时间 -->
    <view class="card time-card">
      <view class="card-header">订单时间</view>
      <view class="card-body">
        <view class="info-row">
          <text class="time-label">创建时间：</text>
          <text class="time-value">{{createTime}}</text>
        </view>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="footer">
      <!-- 待支付订单显示支付和取消按钮 -->
      <block wx:if="{{statusText === '待支付'}}">
        <button class="btn-cancel" bindtap="cancelOrder">取消订单</button>
        <button class="btn-pay" bindtap="payOrder">去支付</button>
      </block>
      <!-- 已支付订单显示退款按钮 -->
      <block wx:elif="{{statusText === '已支付'}}">
        <button class="btn-back" bindtap="goBack">返回</button>
        <button class="btn-refund" bindtap="refundOrder">申请退款</button>
      </block>
      <!-- 其他订单显示返回按钮 -->
      <button class="btn-back" wx:else bindtap="goBack">返回</button>
    </view>
  </view>
</view>
