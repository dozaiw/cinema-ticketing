/* 容器 */
.chat-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F5F5;
}

/* 头部 */
.header {
  background: #FFFFFF;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #EEEEEE;
  position: sticky;
  top: 0;
  z-index: 100;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.clear-btn {
  font-size: 28rpx;
  color: #FF5722;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx 30rpx;
  overflow-y: auto;
}

/* 消息项 */
.message-item {
  margin-bottom: 30rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 用户消息 */
.message-item.user {
  display: flex;
  justify-content: flex-end;
}

.message-item.user .message-content {
  max-width: 80%;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.message-item.user .time {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.message-item.user .content {
  background: linear-gradient(135deg, #FF5722, #FF7043);
  color: #FFFFFF;
  padding: 20rpx 24rpx;
  border-radius: 20rpx 20rpx 4rpx 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-wrap: break-word;
}

/* AI消息 */
.message-item.ai {
  display: flex;
  justify-content: flex-start;
}

.message-item.ai .message-content {
  max-width: 80%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.message-item.ai .time {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.message-item.ai .content {
  background: #FFFFFF;
  color: #333;
  padding: 20rpx 24rpx;
  border-radius: 20rpx 20rpx 20rpx 4rpx;
  font-size: 28rpx;
  line-height: 1.8;
  word-wrap: break-word;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.message-item.ai .content strong {
  color: #FF5722;
  font-weight: bold;
}

.message-item.ai .content em {
  font-style: italic;
  color: #666;
}

.message-item.ai .content p {
  margin: 10rpx 0;
}

/* 系统消息 */
.message-item.system {
  display: flex;
  justify-content: center;
}

.message-item.system .content {
  background: rgba(0, 0, 0, 0.05);
  color: #666;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  text-align: center;
}

/* 加载动画 */
.loading-more {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-left: 30rpx;
}

.loading-text {
  font-size: 24rpx;
  color: #999;
  margin-right: 15rpx;
}

.loading-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #FF5722;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out;
}

.dot:nth-child(1) {
  animation-delay: -0.32s;
}

.dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0.8);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 空状态 */
.empty-tips {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.tips-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.tips-text {
  font-size: 28rpx;
  color: #999;
}

/* 输入区域 */
.input-area {
  background: #FFFFFF;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #EEEEEE;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 48rpx;
  padding: 8rpx 16rpx;
}

.input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #333;
  padding: 0 20rpx;
}

.send-btn {
  background: linear-gradient(90deg, #FF5722, #FF7043);
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 36rpx;
  border: none;
  margin: 0;
  line-height: 1;
  box-shadow: 0 4rpx 12rpx rgba(255, 87, 34, 0.3);
}

.send-btn[disabled] {
  background: #CCCCCC;
  box-shadow: none;
}

.send-btn:active:not([disabled]) {
  opacity: 0.9;
}
