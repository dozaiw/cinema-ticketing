<view class="schedule-container">
  <!-- 1. 电影信息卡片 -->
  <view class="movie-card">
    <image src="{{movie.poster}}" mode="aspectFill" class="movie-poster" />
    <view class="movie-info">
      <text class="movie-title">{{movie.title}}</text>
      <view class="movie-tags">
        <text class="tag">{{movie.duration}}分钟</text>
        <text class="tag" wx:for="{{movie.genres}}" wx:key="id">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 2. 日期选择器 -->
  <view class="date-bar">
    <scroll-view scroll-x class="date-scroll">
      <view 
        class="date-item {{currentIndex === index ? 'active' : ''}}" 
        wx:for="{{dateList}}" 
        wx:key="date"
        bindtap="selectDate"
        data-index="{{index}}"
      >
        <text class="date-week">{{item.week}}</text>
        <text class="date-day">{{item.day}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 3. 影院列表（包含场次） -->
  <view class="cinema-list" wx:if="{{cinemaList.length > 0}}">
    <view class="cinema-item" wx:for="{{cinemaList}}" wx:key="id">
      <!-- 影院信息 -->
      <view class="cinema-header" bindtap="goCinemaDetail" data-cinema="{{item}}">
        <view class="cinema-info">
          <text class="cinema-name">{{item.name}}</text>
          <text class="cinema-address">{{item.address}}</text>
        </view>
        <view class="cinema-price">
          <text class="price">¥{{item.minPrice || 35}}</text>
          <text class="price-unit">起</text>
        </view>
      </view>

      <!-- 标签 -->
      <view class="cinema-tags" wx:if="{{item.tags && item.tags.length > 0}}">
        <text class="tag-item" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
      </view>

      <!-- 场次时间（直接从 cinemaList 中获取，不需要再请求） -->
      <view class="schedule-list" wx:if="{{item.schedules && item.schedules.length > 0}}">
        <text class="schedule-label">近期场次：</text>
        <view class="schedule-times">
          <view 
            class="schedule-time {{item.status === 0 ? 'sold-out' : ''}}"
            wx:for="{{item.schedules}}" 
            wx:key="id"
            bindtap="selectSchedule"
            data-schedule="{{item}}"
          >
            <text class="time">{{formatTime(item.startTime)}}</text>
            <text class="hall">{{item.hallName || '厅'}}</text>
            <text class="price">¥{{item.price}}</text>
          </view>
        </view>
      </view>

      <!-- 无场次提示 -->
      <view class="no-schedule" wx:else>
        <text class="no-schedule-text">该日期暂无场次</text>
      </view>
    </view>
  </view>

  <!-- 4. 无数据提示 -->
  <view class="empty" wx:else>
    <text class="empty-icon">🎬</text>
    <text class="empty-text">该日期暂无排片</text>
  </view>
</view>